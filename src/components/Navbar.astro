---
// Navbar component for NexoFit with integrated search
---

<nav class="bg-zinc-900/95 backdrop-blur-sm border-b border-zinc-800 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 gap-4">
      
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2 group shrink-0">
        <div class="flex justify-center">
            <img src="/logo-192x192.png" alt="NexoFit Logo" class="w-12 h-12" />
        </div>
        <span class="text-xl font-bold text-white">NexoFit</span>
      </a>

      <!-- Desktop Search Bar (hidden for instructors) -->
      <div id="desktop-search-container" class="hidden md:flex flex-1 max-w-md mx-4 relative">
        <div class="relative w-full">
          <input 
            type="text" 
            id="search-input"
            placeholder="Buscar modalidades..." 
            class="w-full bg-zinc-800 text-white placeholder-zinc-400 px-4 py-2 pl-10 rounded-lg border border-zinc-700 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
            autocomplete="off"
          />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          
          <!-- Search Results Dropdown -->
          <div 
            id="search-results"
            class="hidden absolute top-full mt-2 w-full bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl overflow-hidden z-50"
          >
            <div id="search-loading" class="hidden p-4 text-center text-zinc-400">
              <div class="animate-spin w-6 h-6 border-2 border-orange-500 border-t-transparent rounded-full mx-auto"></div>
              <p class="mt-2 text-sm">Buscando...</p>
            </div>
            <div id="search-items" class="max-h-100 overflow-y-auto"></div>
            <div id="search-empty" class="hidden p-4 text-center text-zinc-400">
              <svg class="w-10 h-10 mx-auto mb-2 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M12 12h.01M12 12h.01M12 12h.01M12 12h.01M12 12h.01M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z" />
              </svg>
              <p class="text-sm">No se encontraron resultados</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-6 shrink-0">
        <a href="/" class="text-zinc-300 hover:text-white transition-colors">
          Inicio
        </a>
        <a id="desktop-dashboard-link" href="/dashboard" class="hidden text-zinc-300 hover:text-white transition-colors">
          Dashboard
        </a>
        <a id="desktop-categorias-link" href="/categorias" class="text-zinc-300 hover:text-white transition-colors">
          Categorías
        </a>
      </div>

      <!-- Auth Buttons (for non-authenticated) -->
      <div id="auth-buttons" class="hidden md:flex items-center space-x-4 shrink-0">
        <a 
          href="/login" 
          class="text-zinc-300 hover:text-white transition-colors px-4 py-2"
        >
          Iniciar Sesión
        </a>
        <a 
          href="/register" 
          class="gradient-primary text-white font-semibold px-5 py-2 rounded-lg hover:shadow-lg hover:shadow-orange-500/30 transition-all"
        >
          Registrarse
        </a>
      </div>

      <!-- User Menu (for authenticated users, hidden by default) -->
      <div id="user-menu" class="hidden items-center space-x-3 shrink-0">
        <!-- Profile Dropdown -->
        <div class="relative">
          <button 
            id="profile-dropdown-btn"
            class="flex items-center space-x-3 px-3 py-2 rounded-lg hover:bg-zinc-800 transition-all group"
            aria-label="User menu"
          >
            <!-- Profile Image or Avatar -->
            <div id="user-avatar" class="w-10 h-10 rounded-full bg-linear-to-br from-orange-500 to-amber-400 flex items-center justify-center text-white font-bold text-sm overflow-hidden ring-2 ring-zinc-700 group-hover:ring-orange-500 transition-all">
              <img id="user-image" class="w-full h-full object-cover hidden" alt="Profile" />
              <span id="user-initials"></span>
            </div>
            <!-- User Name -->
            <span id="user-name" class="hidden lg:block text-white font-medium"></span>
            <!-- Chevron -->
            <svg id="chevron-icon" class="w-4 h-4 text-zinc-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown Menu -->
          <div 
            id="profile-dropdown-menu"
            class="hidden absolute right-0 mt-2 w-56 bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl overflow-hidden"
          >
            <!-- User Info Header -->
            <div class="px-4 py-3 border-b border-zinc-800">
              <p id="dropdown-user-name" class="text-sm font-semibold text-white"></p>
              <p id="dropdown-user-email" class="text-xs text-zinc-400 truncate"></p>
            </div>

            <!-- Menu Items -->
            <div class="py-2">
              <a 
                href="/dashboard" 
                class="flex items-center space-x-3 px-4 py-2.5 text-zinc-300 hover:bg-zinc-800 hover:text-white transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                <span>Dashboard</span>
              </a>
              <a 
                href="/perfil" 
                class="flex items-center space-x-3 px-4 py-2.5 text-zinc-300 hover:bg-zinc-800 hover:text-white transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span>Editar Perfil</span>
              </a>
            </div>

            <!-- Logout -->
            <div class="border-t border-zinc-800 py-2">
              <button 
                id="logout-btn"
                class="flex items-center space-x-3 px-4 py-2.5 text-red-400 hover:bg-zinc-800 hover:text-red-300 transition-colors w-full text-left"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                <span>Cerrar Sesión</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button 
        id="mobile-menu-btn"
        class="md:hidden text-zinc-300 hover:text-white shrink-0"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu (hidden by default) -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-zinc-800">
    <div class="px-4 py-4 space-y-3">
      <!-- Mobile Search Bar (hidden for instructors) -->
      <div id="mobile-search-container" class="relative mb-4">
        <input 
          type="text" 
          id="mobile-search-input"
          placeholder="Buscar modalidades..." 
          class="w-full bg-zinc-800 text-white placeholder-zinc-400 px-4 py-2 pl-10 rounded-lg border border-zinc-700 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
          autocomplete="off"
        />
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        
        <!-- Mobile Search Results -->
        <div 
          id="mobile-search-results"
          class="hidden absolute top-full mt-2 w-full bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl overflow-hidden z-50"
        >
          <div id="mobile-search-loading" class="hidden p-4 text-center text-zinc-400">
            <div class="animate-spin w-6 h-6 border-2 border-orange-500 border-t-transparent rounded-full mx-auto"></div>
            <p class="mt-2 text-sm">Buscando...</p>
          </div>
          <div id="mobile-search-items" class="max-h-75 overflow-y-auto"></div>
          <div id="mobile-search-empty" class="hidden p-4 text-center text-zinc-400">
            <svg class="w-10 h-10 mx-auto mb-2 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M12 12h.01M12 12h.01M12 12h.01M12 12h.01M12 12h.01M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z" />
            </svg>
            <p class="text-sm">No se encontraron resultados</p>
          </div>
        </div>
      </div>

      <a href="/" class="block text-zinc-300 hover:text-white transition-colors py-2">
        Inicio
      </a>
      <a id="mobile-dashboard-link" href="/dashboard" class="hidden text-zinc-300 hover:text-white transition-colors py-2">
        Dashboard
      </a>
      <a id="mobile-categorias-link" href="/categorias" class="block text-zinc-300 hover:text-white transition-colors py-2">
        Categorías
      </a>
      
      <!-- Mobile auth buttons (for non-authenticated) -->
      <div id="mobile-auth-buttons" class="pt-4 space-y-2">
        <a 
          href="/login" 
          class="block text-center text-zinc-300 hover:text-white transition-colors py-2 rounded-lg hover:bg-zinc-800"
        >
          Iniciar Sesión
        </a>
        <a 
          href="/register" 
          class="block text-center gradient-primary text-white font-semibold py-2 rounded-lg"
        >
          Registrarse
        </a>
      </div>

      <!-- Mobile user menu (for authenticated, hidden by default) -->
      <div id="mobile-user-menu" class="hidden pt-4">
        <!-- User Info -->
        <div class="flex items-center space-x-3 pb-4 border-b border-zinc-800">
          <div id="mobile-user-avatar" class="w-12 h-12 rounded-full bg-linear-to-br from-orange-500 to-amber-400 flex items-center justify-center text-white font-bold overflow-hidden ring-2 ring-zinc-700">
            <img id="mobile-user-image" class="w-full h-full object-cover hidden" alt="Profile" />
            <span id="mobile-user-initials"></span>
          </div>
          <div>
            <p id="mobile-user-name" class="text-white font-semibold text-sm"></p>
            <p id="mobile-user-email" class="text-zinc-400 text-xs"></p>
          </div>
        </div>

        <!-- Menu Links -->
        <div class="space-y-2 pt-4">
          <a 
            href="/perfil" 
            class="flex items-center space-x-2 text-zinc-300 hover:text-white transition-colors py-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span>Editar Perfil</span>
          </a>
          <button 
            class="mobile-logout-btn flex items-center space-x-2 text-red-400 hover:text-red-300 transition-colors py-2 w-full"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            <span>Cerrar Sesión</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  //@ts-ignore
  import { api } from '../lib/api';

  // Client-side authentication logic
  document.addEventListener('DOMContentLoaded', () => {
    const token = localStorage.getItem('accessToken');
    const userStr = localStorage.getItem('user');
    
    // Elements
    const authButtons = document.getElementById('auth-buttons');
    const userMenu = document.getElementById('user-menu');
    const mobileAuthButtons = document.getElementById('mobile-auth-buttons');
    const mobileUserMenu = document.getElementById('mobile-user-menu');
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    // Profile dropdown elements
    const profileDropdownBtn = document.getElementById('profile-dropdown-btn');
    const profileDropdownMenu = document.getElementById('profile-dropdown-menu');
    const chevronIcon = document.getElementById('chevron-icon');
    
    // Navigation elements
    const desktopSearchContainer = document.getElementById('desktop-search-container');
    const mobileSearchContainer = document.getElementById('mobile-search-container');
    const desktopDashboardLink = document.getElementById('desktop-dashboard-link');
    const mobileDashboardLink = document.getElementById('mobile-dashboard-link');
    const desktopCategoriasLink = document.getElementById('desktop-categorias-link');
    const mobileCategoriasLink = document.getElementById('mobile-categorias-link');
    const desktopClasesLink = document.getElementById('desktop-clases-link');
    const mobileClasesLink = document.getElementById('mobile-clases-link');
    
    // User info elements
    const userImage = document.getElementById('user-image') as HTMLImageElement;
    const userInitials = document.getElementById('user-initials');
    const userName = document.getElementById('user-name');
    const dropdownUserName = document.getElementById('dropdown-user-name');
    const dropdownUserEmail = document.getElementById('dropdown-user-email');
    
    // Mobile user info elements
    const mobileUserImage = document.getElementById('mobile-user-image') as HTMLImageElement;
    const mobileUserInitials = document.getElementById('mobile-user-initials');
    const mobileUserName = document.getElementById('mobile-user-name');
    const mobileUserEmail = document.getElementById('mobile-user-email');
    
    // Logout buttons
    const logoutBtn = document.getElementById('logout-btn');
    const mobileLogoutBtns = document.querySelectorAll('.mobile-logout-btn');

    // Search elements
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchResults = document.getElementById('search-results');
    const searchLoading = document.getElementById('search-loading');
    const searchItems = document.getElementById('search-items');
    const searchEmpty = document.getElementById('search-empty');

    // Mobile search elements
    const mobileSearchInput = document.getElementById('mobile-search-input') as HTMLInputElement;
    const mobileSearchResults = document.getElementById('mobile-search-results');
    const mobileSearchLoading = document.getElementById('mobile-search-loading');
    const mobileSearchItems = document.getElementById('mobile-search-items');
    const mobileSearchEmpty = document.getElementById('mobile-search-empty');

    // Get user initials
    function getInitials(firstName: string, lastName: string): string {
      const first = firstName?.charAt(0) || '';
      const last = lastName?.charAt(0) || '';
      return (first + last).toUpperCase();
    }

    // Toggle mobile menu
    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
    
    // Check authentication status
    if (token && userStr) {
      try {
        const userData = JSON.parse(userStr);
        const isInstructor = userData.role === 'instructor';
        
        // Hide auth buttons, show user menu
        if (authButtons) {
          authButtons.classList.remove('md:flex', 'flex');
          authButtons.classList.add('hidden');
        }
        if (userMenu) {
          userMenu.classList.remove('hidden');
          userMenu.classList.add('flex', 'md:flex');
        }
        if (mobileAuthButtons) {
          mobileAuthButtons.classList.add('hidden');
        }
        if (mobileUserMenu) {
          mobileUserMenu.classList.remove('hidden');
        }
        
        // Show Dashboard link in navigation for all authenticated users
        if (desktopDashboardLink) {
          desktopDashboardLink.classList.remove('hidden');
        }
        if (mobileDashboardLink) {
          mobileDashboardLink.classList.remove('hidden');
          mobileDashboardLink.classList.add('block');
        }
        
        // Hide search bars, Categorías, and Clases for instructors
        if (isInstructor) {
          // Hide search bars
          if (desktopSearchContainer) {
            desktopSearchContainer.classList.add('hidden');
            desktopSearchContainer.classList.remove('md:flex');
          }
          if (mobileSearchContainer) {
            mobileSearchContainer.classList.add('hidden');
          }
          
          // Hide Categorías and Clases links
          if (desktopCategoriasLink) {
            desktopCategoriasLink.classList.add('hidden');
          }
          if (mobileCategoriasLink) {
            mobileCategoriasLink.classList.add('hidden');
            mobileCategoriasLink.classList.remove('block');
          }
          if (desktopClasesLink) {
            desktopClasesLink.classList.add('hidden');
          }
          if (mobileClasesLink) {
            mobileClasesLink.classList.add('hidden');
            mobileClasesLink.classList.remove('block');
          }
        }
        
        // Set user name
        const fullName = `${userData.first_name} ${userData.last_name}`;
        if (userName) userName.textContent = userData.first_name;
        if (dropdownUserName) dropdownUserName.textContent = fullName;
        if (dropdownUserEmail) dropdownUserEmail.textContent = userData.email;
        if (mobileUserName) mobileUserName.textContent = fullName;
        if (mobileUserEmail) mobileUserEmail.textContent = userData.email;
        
        // Set profile image or initials
        const initials = getInitials(userData.first_name, userData.last_name);
        if (userInitials) userInitials.textContent = initials;
        if (mobileUserInitials) mobileUserInitials.textContent = initials;
        
        // If user has image_url, show image
        if (userData.image_url) {
          if (userImage) {
            userImage.src = userData.image_url;
            userImage.classList.remove('hidden');
            if (userInitials) userInitials.classList.add('hidden');
          }
          if (mobileUserImage) {
            mobileUserImage.src = userData.image_url;
            mobileUserImage.classList.remove('hidden');
            if (mobileUserInitials) mobileUserInitials.classList.add('hidden');
          }
        }
        
      } catch (error) {
        console.error('Error parsing user data:', error);
        // Show auth buttons if there's an error
        if (authButtons) {
          authButtons.classList.remove('hidden');
          authButtons.classList.add('md:flex');
        }
        if (userMenu) {
          userMenu.classList.remove('flex', 'md:flex');
          userMenu.classList.add('hidden');
        }
      }
    } else {
      // Show auth buttons, hide user menu
      if (authButtons) {
        authButtons.classList.remove('hidden');
        authButtons.classList.add('md:flex');
      }
      if (userMenu) {
        userMenu.classList.remove('flex', 'md:flex');
        userMenu.classList.add('hidden');
      }
      if (mobileAuthButtons) {
        mobileAuthButtons.classList.remove('hidden');
      }
      if (mobileUserMenu) {
        mobileUserMenu.classList.add('hidden');
      }
    }

    // Toggle profile dropdown
    let isDropdownOpen = false;
    
    profileDropdownBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      isDropdownOpen = !isDropdownOpen;
      
      if (isDropdownOpen) {
        profileDropdownMenu?.classList.remove('hidden');
        chevronIcon?.classList.add('rotate-180');
      } else {
        profileDropdownMenu?.classList.add('hidden');
        chevronIcon?.classList.remove('rotate-180');
      }
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (isDropdownOpen && profileDropdownMenu && !profileDropdownMenu.contains(e.target as Node)) {
        profileDropdownMenu.classList.add('hidden');
        chevronIcon?.classList.remove('rotate-180');
        isDropdownOpen = false;
      }
    });

    // Logout functionality
    const handleLogout = () => {
      localStorage.removeItem('accessToken');
      localStorage.removeItem('refreshToken');
      localStorage.removeItem('user');
      sessionStorage.removeItem('isRedirecting');
      window.location.href = '/login';
    };

    logoutBtn?.addEventListener('click', handleLogout);
    mobileLogoutBtns.forEach(btn => btn.addEventListener('click', handleLogout));

    // Search functionality
    let searchTimeout: ReturnType<typeof setTimeout> | null = null;
    let currentQuery = '';

    function createModalityCard(modality: any): string {
      const image = modality.image_url || '/placeholder.jpg';
      return `
        <a href="/modalidades/${modality.id}" class="flex items-start gap-3 p-3 hover:bg-zinc-800 transition-colors group">
          <img 
            src="${image}" 
            alt="${modality.title}"
            class="w-16 h-16 object-cover rounded-lg flex-shrink-0"
            onerror="this.src='/placeholder.jpg'"
          />
          <div class="flex-1 min-w-0">
            <h3 class="text-white font-semibold text-sm group-hover:text-orange-500 transition-colors truncate">
              ${modality.title}
            </h3>
            <p class="text-zinc-400 text-xs mt-0.5">
              ${modality.category_title || 'Sin categoría'}
            </p>
            <p class="text-zinc-500 text-xs mt-1 line-clamp-2">
              ${modality.description || 'Sin descripción'}
            </p>
          </div>
        </a>
      `;
    }

    async function performSearch(query: string, isMobile: boolean = false) {
      if (query.trim().length < 2) {
        // Hide results if query is too short
        if (isMobile) {
          mobileSearchResults?.classList.add('hidden');
        } else {
          searchResults?.classList.add('hidden');
        }
        return;
      }

      currentQuery = query;

      // Show loading state
      const resultsContainer = isMobile ? mobileSearchResults : searchResults;
      const loadingEl = isMobile ? mobileSearchLoading : searchLoading;
      const itemsEl = isMobile ? mobileSearchItems : searchItems;
      const emptyEl = isMobile ? mobileSearchEmpty : searchEmpty;

      resultsContainer?.classList.remove('hidden');
      loadingEl?.classList.remove('hidden');
      itemsEl!.innerHTML = '';
      emptyEl?.classList.add('hidden');

      try {
        const response = await api.searchModalities(query, 8);
        
        // Check if query changed while fetching
        if (currentQuery !== query) return;

        loadingEl?.classList.add('hidden');

        const modalities = response.data || [];

        if (modalities.length === 0) {
          emptyEl?.classList.remove('hidden');
        } else {
          itemsEl!.innerHTML = modalities.map((m: any) => createModalityCard(m)).join('');
        }
      } catch (error) {
        console.error('Error searching modalities:', error);
        loadingEl?.classList.add('hidden');
        emptyEl?.classList.remove('hidden');
      }
    }

    // Desktop search
    searchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value;
      
      if (searchTimeout) {
        clearTimeout(searchTimeout);
      }

      searchTimeout = setTimeout(() => {
        performSearch(query, false);
      }, 300);
    });

    // Close search results when clicking outside (desktop)
    document.addEventListener('click', (e) => {
      if (searchResults && !searchResults.contains(e.target as Node) && e.target !== searchInput) {
        searchResults.classList.add('hidden');
      }
    });

    // Mobile search
    mobileSearchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value;
      
      if (searchTimeout) {
        clearTimeout(searchTimeout);
      }

      searchTimeout = setTimeout(() => {
        performSearch(query, true);
      }, 300);
    });

    // Close mobile search results when clicking outside
    document.addEventListener('click', (e) => {
      if (mobileSearchResults && !mobileSearchResults.contains(e.target as Node) && e.target !== mobileSearchInput) {
        mobileSearchResults.classList.add('hidden');
      }
    });

    // Handle ESC key to close search results
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchResults?.classList.add('hidden');
        mobileSearchResults?.classList.add('hidden');
      }
    });
  });
</script>
