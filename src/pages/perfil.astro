---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mi Perfil - NexoFit" description="Edita tu información personal">
	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<!-- Header -->
		<div class="mb-8">
			<h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
				Mi Perfil
			</h1>
			<p class="text-zinc-400">Gestiona tu información personal y preferencias</p>
		</div>

		<!-- Loading State -->
		<div id="loading-screen" class="flex items-center justify-center py-20">
			<svg class="animate-spin h-10 w-10 text-orange-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
				<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
				<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
			</svg>
		</div>

		<!-- Profile Content -->
		<div id="profile-content" class="hidden space-y-6">
			<!-- Profile Picture Section -->
			<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
				<h2 class="text-xl font-bold text-white mb-4">Foto de Perfil</h2>
				<div class="flex items-center space-x-6 mb-4">
					<div id="profile-avatar" class="w-24 h-24 rounded-full bg-linear-to-br from-orange-500 to-amber-400 flex items-center justify-center text-white font-bold text-3xl overflow-hidden ring-4 ring-zinc-800">
						<img id="profile-image" class="w-full h-full object-cover hidden" alt="Profile" />
						<span id="profile-initials"></span>
					</div>
					<div class="flex-1">
						<label for="image_url" class="block text-sm font-medium text-zinc-300 mb-2">
							URL de Imagen
						</label>
						<input
							id="image_url"
							name="image_url"
							type="url"
							placeholder="https://ejemplo.com/mi-foto.jpg"
							class="w-full px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
						/>
						<p class="text-zinc-400 text-xs mt-2">Ingresa la URL de tu foto de perfil</p>
					</div>
				</div>
			</div>

			<!-- Personal Information Form -->
			<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
				<h2 class="text-xl font-bold text-white mb-6">Información Personal</h2>
				
				<form id="profile-form" class="space-y-6">
					<!-- Name Fields -->
					<div class="grid md:grid-cols-2 gap-6">
						<div>
							<label for="first_name" class="block text-sm font-medium text-zinc-300 mb-2">
								Nombre
							</label>
							<input
								id="first_name"
								name="first_name"
								type="text"
								required
								class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
							/>
						</div>
						<div>
							<label for="last_name" class="block text-sm font-medium text-zinc-300 mb-2">
								Apellido
							</label>
							<input
								id="last_name"
								name="last_name"
								type="text"
								required
								class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
							/>
						</div>
					</div>

					<!-- Email -->
					<div>
						<label for="email" class="block text-sm font-medium text-zinc-300 mb-2">
							Correo Electrónico
						</label>
						<input
							id="email"
							name="email"
							type="email"
							readonly
							class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-zinc-400 placeholder-zinc-500 cursor-not-allowed"
						/>
						<p class="text-zinc-500 text-xs mt-1">El correo electrónico no puede ser modificado</p>
					</div>

					<!-- Phone -->
					<div>
						<label for="phone" class="block text-sm font-medium text-zinc-300 mb-2">
							Teléfono
						</label>
						<input
							id="phone"
							name="phone"
							type="tel"
							class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
						/>
					</div>

					<!-- Role Badge -->
					<div>
						<label class="block text-sm font-medium text-zinc-300 mb-2">
							Tipo de Cuenta
						</label>
						<div id="role-badge" class="inline-block px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg">
							<span id="role-text" class="text-white font-semibold"></span>
						</div>
					</div>

					<!-- Submit Button -->
					<div class="flex items-center justify-end space-x-4 pt-4">
						<button
							type="submit"
							id="submit-btn"
							class="gradient-primary text-white font-bold px-8 py-3 rounded-lg hover:shadow-xl hover:shadow-orange-500/30 transition-all duration-300 transform hover:scale-[1.02] disabled:opacity-50 disabled:cursor-not-allowed"
						>
							<span id="button-text">Guardar Cambios</span>
							<span id="button-loading" class="hidden">Guardando...</span>
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</Layout>

<script>
	// @ts-nocheck
	import { getUser, redirectIfNotAuthenticated } from '../lib/auth';

	// Redirect if not authenticated
	const shouldRedirect = redirectIfNotAuthenticated();
	if (shouldRedirect) {
		throw new Error('Redirecting...');
	}

	const user = getUser();
	if (!user) {
		window.location.href = '/login';
		throw new Error('Redirecting...');
	}

	const loadingScreen = document.getElementById('loading-screen');
	const profileContent = document.getElementById('profile-content');
	
	// Profile elements
	const profileImage = document.getElementById('profile-image');
	const profileInitials = document.getElementById('profile-initials');
	
	// Form elements
	const form = document.getElementById('profile-form');
	const firstNameInput = document.getElementById('first_name');
	const lastNameInput = document.getElementById('last_name');
	const emailInput = document.getElementById('email');
	const phoneInput = document.getElementById('phone');
	const imageUrlInput = document.getElementById('image_url');
	const roleBadge = document.getElementById('role-text');
	const submitBtn = document.getElementById('submit-btn');
	const buttonText = document.getElementById('button-text');
	const buttonLoading = document.getElementById('button-loading');

	// Get initials
	function getInitials(firstName, lastName) {
		const first = firstName?.charAt(0) || '';
		const last = lastName?.charAt(0) || '';
		return (first + last).toUpperCase();
	}

	// Load user data
	function loadUserData() {
		// Set profile picture or initials
		const initials = getInitials(user.first_name, user.last_name);
		profileInitials.textContent = initials;

		if (user.image_url) {
			profileImage.src = user.image_url;
			profileImage.classList.remove('hidden');
			profileInitials.classList.add('hidden');
		}

		// Fill form
		firstNameInput.value = user.first_name;
		lastNameInput.value = user.last_name;
		emailInput.value = user.email;
		phoneInput.value = user.phone || '';
		imageUrlInput.value = user.image_url || '';

		// Set role badge
		const roleLabels = {
			'client': 'Cliente',
			'instructor': 'Instructor',
			'admin': 'Administrador'
		};
		roleBadge.textContent = roleLabels[user.role] || user.role;

		// Show content
		loadingScreen.classList.add('hidden');
		profileContent.classList.remove('hidden');
	}

	// Update profile UI with new data
	function updateProfileUI(updatedData) {
		// Update form fields
		firstNameInput.value = updatedData.first_name;
		lastNameInput.value = updatedData.last_name;
		phoneInput.value = updatedData.phone || '';
		imageUrlInput.value = updatedData.image_url || '';

		// Update profile picture
		const initials = getInitials(updatedData.first_name, updatedData.last_name);
		profileInitials.textContent = initials;

		if (updatedData.image_url) {
			profileImage.src = updatedData.image_url;
			profileImage.classList.remove('hidden');
			profileInitials.classList.add('hidden');
		} else {
			profileImage.classList.add('hidden');
			profileInitials.classList.remove('hidden');
		}

		// Update navbar if it exists
		const navbarUserName = document.querySelector('.navbar-user-name');
		if (navbarUserName) {
			navbarUserName.textContent = `${updatedData.first_name} ${updatedData.last_name}`;
		}
	}

	// Handle form submission
	function setLoading(loading) {
		submitBtn.disabled = loading;
		if (loading) {
			buttonText.classList.add('hidden');
			buttonLoading.classList.remove('hidden');
		} else {
			buttonText.classList.remove('hidden');
			buttonLoading.classList.add('hidden');
		}
	}

	form.addEventListener('submit', async (e) => {
		e.preventDefault();
		setLoading(true);

		try {
			// Importar dinámicamente el cliente API
			const { api } = await import('../lib/api');
			
			// Preparar datos para actualizar
			const profileData = {
				first_name: firstNameInput.value.trim(),
				last_name: lastNameInput.value.trim(),
				phone: phoneInput.value.trim() || null,
				image_url: imageUrlInput.value.trim() || null
			};

			// Llamar al backend para actualizar el perfil
			const response = await api.updateProfile(profileData);

			if (!response.success) {
				window.toast.error(response.error || 'Error al actualizar el perfil');
				setLoading(false);
				return;
			}

			// Actualizar localStorage con los datos del servidor
			const updatedUser = {
				...user,
				...response.data
			};
			localStorage.setItem('user', JSON.stringify(updatedUser));
			
			// Actualizar la UI con los nuevos datos
			updateProfileUI(updatedUser);
			
			window.toast.success('Perfil actualizado correctamente');
			setLoading(false);
		} catch (error) {
			console.error('Error al actualizar perfil:', error);
			window.toast.error('Error de conexión con el servidor');
			setLoading(false);
		}
	});

	// Update image preview when URL changes
	imageUrlInput.addEventListener('input', (e) => {
		const url = e.target.value.trim();
		
		if (url) {
			// Try to load the image
			const tempImg = new Image();
			tempImg.onload = () => {
				// Image loaded successfully
				profileImage.src = url;
				profileImage.classList.remove('hidden');
				profileInitials.classList.add('hidden');
			};
			tempImg.onerror = () => {
				// Image failed to load, show initials
				profileImage.classList.add('hidden');
				profileInitials.classList.remove('hidden');
			};
			tempImg.src = url;
		} else {
			// No URL, show initials
			profileImage.classList.add('hidden');
			profileInitials.classList.remove('hidden');
		}
	});

	// Initialize
	loadUserData();
</script>
