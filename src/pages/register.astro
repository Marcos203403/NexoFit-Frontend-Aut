---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Crear Cuenta - NexoFit" description="Regístrate en NexoFit y comienza tu transformación">
	<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
		<div class="max-w-md w-full space-y-8">
			<!-- Logo -->
			<div class="text-center">
				<img src="/logo-192x192.png" alt="NexoFit Logo" class="mx-auto h-20 w-20" />
				<h2 class="mt-6 text-3xl font-bold text-white">
					Únete a NexoFit
				</h2>
				<p class="mt-2 text-sm text-zinc-400">
					Crea tu cuenta y comienza tu transformación hoy
				</p>
			</div>

			<!-- Register Form -->
			<div class="bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl p-8">
				<form id="register-form" class="space-y-6">
					<!-- Error Message -->
					<div id="error-message" class="hidden bg-red-500/10 border border-red-500/50 rounded-lg p-4">
						<p class="text-red-400 text-sm" id="error-text"></p>
					</div>

					<!-- Success Message -->
					<div id="success-message" class="hidden bg-green-500/10 border border-green-500/50 rounded-lg p-4">
						<p class="text-green-400 text-sm">¡Cuenta creada! Redirigiendo...</p>
					</div>

					<!-- Name Fields -->
					<div class="grid grid-cols-2 gap-4">
						<div>
							<label for="firstName" class="block text-sm font-medium text-zinc-300 mb-2">
								Nombre
							</label>
							<input
								id="firstName"
								name="firstName"
								type="text"
								required
								class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
								placeholder="Juan"
							/>
						</div>
						<div>
							<label for="lastName" class="block text-sm font-medium text-zinc-300 mb-2">
								Apellido
							</label>
							<input
								id="lastName"
								name="lastName"
								type="text"
								required
								class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
								placeholder="Pérez"
							/>
						</div>
					</div>

					<!-- Email -->
					<div>
						<label for="email" class="block text-sm font-medium text-zinc-300 mb-2">
							Correo Electrónico
						</label>
						<input
							id="email"
							name="email"
							type="email"
							autocomplete="email"
							required
							class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
							placeholder="tu@email.com"
						/>
					</div>

					<!-- Phone -->
					<div>
						<label for="phone" class="block text-sm font-medium text-zinc-300 mb-2">
							Teléfono <span class="text-zinc-500">(opcional)</span>
						</label>
						<input
							id="phone"
							name="phone"
							type="tel"
							class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
							placeholder="555-0000"
						/>
					</div>

					<!-- Password -->
					<div>
						<label for="password" class="block text-sm font-medium text-zinc-300 mb-2">
							Contraseña
						</label>
						<input
							id="password"
							name="password"
							type="password"
							autocomplete="new-password"
							required
							minlength="6"
							class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
							placeholder="••••••••"
						/>
						<p class="mt-1 text-xs text-zinc-500">Mínimo 6 caracteres</p>
					</div>

					<!-- Confirm Password -->
					<div>
						<label for="confirmPassword" class="block text-sm font-medium text-zinc-300 mb-2">
							Confirmar Contraseña
						</label>
						<input
							id="confirmPassword"
							name="confirmPassword"
							type="password"
							autocomplete="new-password"
							required
							minlength="6"
							class="w-full px-4 py-3 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-all"
							placeholder="••••••••"
						/>
					</div>

					<!-- Terms -->
					<div class="flex items-start">
						<input
							id="terms"
							name="terms"
							type="checkbox"
							required
							class="h-4 w-4 mt-1 bg-zinc-800 border-zinc-700 rounded text-orange-500 focus:ring-orange-500"
						/>
						<label for="terms" class="ml-2 block text-sm text-zinc-400">
							Acepto los <a href="#" class="text-orange-500 hover:text-orange-400">términos y condiciones</a> y la <a href="#" class="text-orange-500 hover:text-orange-400">política de privacidad</a>
						</label>
					</div>

					<!-- Submit Button -->
					<button
						type="submit"
						id="submit-btn"
						class="w-full gradient-primary text-white font-bold py-3 px-4 rounded-lg hover:shadow-xl hover:shadow-orange-500/30 transition-all duration-300 transform hover:scale-[1.02] disabled:opacity-50 disabled:cursor-not-allowed"
					>
						<span id="button-text">Crear Cuenta</span>
						<span id="button-loading" class="hidden">
							<svg class="animate-spin h-5 w-5 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
								<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
								<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
							</svg>
						</span>
					</button>
				</form>

				<!-- Divider -->
				<div class="mt-6">
					<div class="relative">
						<div class="absolute inset-0 flex items-center">
							<div class="w-full border-t border-zinc-700"></div>
						</div>
						<div class="relative flex justify-center text-sm">
							<span class="px-2 bg-zinc-900 text-zinc-400">¿Ya tienes cuenta?</span>
						</div>
					</div>
				</div>

				<!-- Login Link -->
				<div class="mt-6">
					<a
						href="/login"
						class="w-full flex justify-center py-3 px-4 border border-zinc-700 rounded-lg text-zinc-300 hover:bg-zinc-800 hover:text-white transition-all duration-300"
					>
						Iniciar Sesión
					</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	// @ts-nocheck
	import { api } from '../lib/api';
	import { setAuthData, redirectIfAuthenticated } from '../lib/auth';

	// Redirect if already authenticated
	if (redirectIfAuthenticated()) {
		// Stop execution if redirecting
		throw new Error('Redirecting...');
	}

	const form = document.getElementById('register-form');
	const errorMessage = document.getElementById('error-message');
	const successMessage = document.getElementById('success-message');
	const errorText = document.getElementById('error-text');
	const submitBtn = document.getElementById('submit-btn');
	const buttonText = document.getElementById('button-text');
	const buttonLoading = document.getElementById('button-loading');

	function showError(message) {
		errorText.textContent = message;
		errorMessage.classList.remove('hidden');
		successMessage.classList.add('hidden');
	}

	function showSuccess() {
		successMessage.classList.remove('hidden');
		errorMessage.classList.add('hidden');
	}

	function hideMessages() {
		errorMessage.classList.add('hidden');
		successMessage.classList.add('hidden');
	}

	function setLoading(loading) {
		submitBtn.disabled = loading;
		if (loading) {
			buttonText.classList.add('hidden');
			buttonLoading.classList.remove('hidden');
		} else {
			buttonText.classList.remove('hidden');
			buttonLoading.classList.add('hidden');
		}
	}

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		hideMessages();

		const formData = new FormData(form);
		const password = formData.get('password');
		const confirmPassword = formData.get('confirmPassword');

		// Validate passwords match
		if (password !== confirmPassword) {
			showError('Las contraseñas no coinciden');
			return;
		}

		setLoading(true);

		const userData = {
			firstName: formData.get('firstName'),
			lastName: formData.get('lastName'),
			email: formData.get('email'),
			password: password,
			phone: formData.get('phone') || undefined,
		};

		try {
			const response = await api.register(userData);

			if (response.success && response.data) {
				showSuccess();
				
				// Save auth data
				setAuthData(
					response.data.user,
					response.data.accessToken,
					response.data.refreshToken
				);

				// Redirect after a short delay
				setTimeout(() => {
					window.location.href = '/dashboard';
				}, 1500);
			} else {
				showError(response.error || 'Error al crear la cuenta');
				setLoading(false);
			}
		} catch (error) {
			showError('Error de conexión. Por favor intenta de nuevo.');
			setLoading(false);
		}
	});
</script>
