</Layout>

<script>
	// @ts-nocheck
	import { api } from '../lib/api';
	import { getUser, redirectIfNotAuthenticated, isClient, isInstructor } from '../lib/auth';

	// Redirect if not authenticated
	const shouldRedirect = redirectIfNotAuthenticated();
	if (shouldRedirect) {
		// Stop execution if redirecting
		throw new Error('Redirecting...');
	}

	const user = getUser();
	if (!user) {
		// Clear invalid auth data and redirect
		localStorage.removeItem('accessToken');
		localStorage.removeItem('refreshToken');
		localStorage.removeItem('user');
		window.location.href = '/login';
		throw new Error('Redirecting...');
	}

	const loadingScreen = document.getElementById('loading-screen');
	const clientDashboard = document.getElementById('client-dashboard');
	const instructorDashboard = document.getElementById('instructor-dashboard');

	// Format date helper
	function formatDate(dateStr) {
		const date = new Date(dateStr);
		const options = {
			weekday: 'short',
			year: 'numeric',
			month: 'short',
			day: 'numeric',
			hour: '2-digit',
			minute: '2-digit'
		};
		return date.toLocaleDateString('es-ES', options);
	}

	// Load Client Dashboard
	async function loadClientDashboard() {
		document.getElementById('user-name').textContent = user!.first_name;

		// Load upcoming bookings
		const upcomingResponse = await api.getMyUpcomingBookings();
		const upcomingLoading = document.getElementById('upcoming-loading');
		const upcomingEmpty = document.getElementById('upcoming-empty');
		const upcomingList = document.getElementById('upcoming-list');

		console.log('Upcoming bookings response:', upcomingResponse);
		console.log('Has data?', upcomingResponse.success && upcomingResponse.data);
		console.log('Data length:', upcomingResponse.data?.length);
		upcomingLoading.classList.add('hidden');

		if (upcomingResponse.success && upcomingResponse.data && upcomingResponse.data.length > 0) {
			console.log('Showing upcoming classes:', upcomingResponse.data);
			upcomingList.classList.remove('hidden');
			const upcomingGrid = document.getElementById('upcoming-grid');;
			upcomingGrid.innerHTML = upcomingResponse.data.map((booking) => `
				<div class="bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden hover:border-orange-500/50 transition-all">
					<img src="${booking.modality_image}" alt="${booking.modality_name}" class="w-full h-48 object-cover" />
					<div class="p-6">
						<span class="inline-block px-3 py-1 bg-orange-500/20 text-orange-400 text-xs font-semibold rounded-full mb-3">
							${booking.category_name}
						</span>
						<h3 class="text-xl font-bold text-white mb-2">${booking.modality_name}</h3>
						<div class="space-y-2 text-sm text-zinc-400 mb-4">
							<div class="flex items-center">
								<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
								</svg>
								${formatDate(booking.start_time)}
							</div>
							<div class="flex items-center">
								<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
								</svg>
								${booking.instructor_name}
							</div>
						</div>
						<button 
							onclick="cancelBooking(${booking.booking_id})"
							class="w-full bg-red-500/10 hover:bg-red-500/20 text-red-400 font-semibold py-2 rounded-lg transition-all"
						>
							Cancelar Reserva
						</button>
					</div>
				</div>
			`).join('');
		} else {
			console.log('No upcoming classes found, showing empty state');
			upcomingEmpty.classList.remove('hidden');
		}

		// Load available classes
		const classesResponse = await api.getClasses({ futureOnly: true });
		const classesLoading = document.getElementById('classes-loading');
		const classesGrid = document.getElementById('classes-grid');

		console.log('[Dashboard] Classes response:', classesResponse);
		classesLoading.classList.add('hidden');

		if (classesResponse.success && classesResponse.data) {
			classesGrid.classList.remove('hidden');
			renderClasses(classesResponse.data);
		}

		loadingScreen?.classList.add('hidden');
		clientDashboard?.classList.remove('hidden');
	}

	// Render classes for client
	function renderClasses(classes) {
		const classesGrid = document.getElementById('classes-grid');
		const classesGridInner = document.getElementById('classes-grid-inner');
		classesGrid.classList.remove('hidden');
		classesGridInner.innerHTML = classes.map((cls) => {
			const isFull = cls.isFull;
			const isBooked = cls.isBooked;
			
			let buttonHTML = '';
			if (isBooked) {
				buttonHTML = `<button disabled class="w-full bg-green-500/20 text-green-400 font-semibold py-2 rounded-lg cursor-not-allowed flex items-center justify-center space-x-2">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
					</svg>
					<span>Apuntado</span>
				</button>`;
			} else if (isFull) {
				buttonHTML = `<button disabled class="w-full bg-zinc-800 text-zinc-500 font-semibold py-2 rounded-lg cursor-not-allowed flex items-center justify-center space-x-2">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
					</svg>
					<span>Clase Llena</span>
				</button>`;
			} else {
				buttonHTML = `<button onclick="bookClass(${cls.id})" class="w-full gradient-primary text-white font-semibold py-2 rounded-lg hover:shadow-lg hover:shadow-orange-500/30 transition-all">Reservar Plaza</button>`;
			}

			return `
				<div class="bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden hover:border-orange-500/50 transition-all">
					<img src="${cls.modality_image}" alt="${cls.modality_name}" class="w-full h-48 object-cover" />
					<div class="p-6">
						<span class="inline-block px-3 py-1 bg-orange-500/20 text-orange-400 text-xs font-semibold rounded-full mb-3">
							${cls.category_name}
						</span>
						<h3 class="text-xl font-bold text-white mb-2">${cls.modality_name}</h3>
						<p class="text-sm text-zinc-400 mb-4 line-clamp-2">${cls.modality_description}</p>
						<div class="space-y-2 text-sm text-zinc-400 mb-4">
							<div class="flex items-center">
								<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
								</svg>
								${formatDate(cls.start_time)}
							</div>
							<div class="flex items-center">
								<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
								</svg>
								${cls.instructor_name}
							</div>
							<div class="flex items-center justify-between">
								<span>Plazas: ${cls.current_bookings}/${cls.capacity}</span>
								<span class="text-orange-400">${Math.round((cls.current_bookings / cls.capacity) * 100)}%</span>
							</div>
						</div>
						${buttonHTML}
					</div>
				</div>
			`;
		}).join('');
	}

	// Load Instructor Dashboard
	async function loadInstructorDashboard() {
		document.getElementById('instructor-name').textContent = user!.first_name;

		// Load instructor classes
		const classesResponse = await api.getMyClasses();
		const classesLoading = document.getElementById('instructor-classes-loading');
		const classesTable = document.getElementById('instructor-classes-table');
		const classesBody = document.getElementById('instructor-classes-body');

		classesLoading.classList.add('hidden');

		if (classesResponse.success && classesResponse.data) {
			const classes = classesResponse.data;
			classesTable.classList.remove('hidden');

			// Calculate stats
			const totalClasses = classes.length;
			const totalStudents = classes.reduce((sum, cls) => sum + parseInt(cls.current_bookings), 0);
			const avgOccupancy = totalClasses > 0
				? Math.round((totalStudents / classes.reduce((sum, cls) => sum + cls.capacity, 0)) * 100)
				: 0;

			document.getElementById('stat-total-classes').textContent = totalClasses.toString();
			document.getElementById('stat-total-students').textContent = totalStudents.toString();
			document.getElementById('stat-avg-occupancy').textContent = avgOccupancy + '%';

			// Render table
			classesBody.innerHTML = classes.map((cls) => {
				const occupancy = Math.round((parseInt(cls.current_bookings) / cls.capacity) * 100);
				const isFull = occupancy >= 100;
				
				return `
					<tr class="hover:bg-zinc-800/50 transition-colors">
						<td class="px-6 py-4">
							<div class="flex items-center">
								<img src="${cls.modality_image}" alt="${cls.modality_name}" class="w-12 h-12 rounded-lg object-cover mr-3" />
								<div>
									<p class="text-white font-semibold">${cls.modality_name}</p>
									<p class="text-zinc-500 text-sm">${cls.category_name}</p>
								</div>
							</div>
						</td>
						<td class="px-6 py-4 text-zinc-300">${formatDate(cls.start_time)}</td>
						<td class="px-6 py-4">
							<div class="flex items-center space-x-2">
								<div class="flex-1 bg-zinc-800 rounded-full h-2">
									<div class="gradient-primary h-2 rounded-full" style="width: ${occupancy}%"></div>
								</div>
								<span class="text-zinc-300 text-sm">${cls.current_bookings}/${cls.capacity}</span>
							</div>
						</td>
						<td class="px-6 py-4">
							<span class="px-3 py-1 rounded-full text-xs font-semibold ${isFull ? 'bg-red-500/20 text-red-400' : 'bg-green-500/20 text-green-400'}">
								${isFull ? 'Completa' : 'Disponible'}
							</span>
						</td>
					</tr>
				`;
			}).join('');
		}

		// Load all classes
		await loadAllClasses();

		// Load all modalities
		await loadAllModalities();

		// Load all categories
		await loadAllCategories();

		loadingScreen?.classList.add('hidden');
		instructorDashboard?.classList.remove('hidden');
		// Initialize first tab
		switchTab('tab-my-classes');
	}

	// Load all classes for instructor dashboard
	async function loadAllClasses() {
		const response = await api.getClasses();
		const loading = document.getElementById('all-classes-loading');
		const table = document.getElementById('all-classes-table');
		const body = document.getElementById('all-classes-body');

		loading.classList.add('hidden');

		if (response.success && response.data) {
			table.classList.remove('hidden');
			body.innerHTML = response.data.map((cls) => {
