	// Global functions for modality management
	window.editModality = async function(modalityId) {
		// Load categories for the select
		const categoriesResponse = await api.getCategories();
		if (categoriesResponse.success && categoriesResponse.data) {
			const select = document.getElementById('edit-modality-category');
			select.innerHTML = '<option value="">Selecciona una categoría...</option>';
			categoriesResponse.data.forEach((category) => {
				const option = document.createElement('option');
				option.value = category.id;
				option.textContent = category.title;
				select.appendChild(option);
			});
		}

		// Fetch modality data to pre-populate
		const response = await api.getModalities();
		if (response.success && response.data) {
			const modality = response.data.find((m) => m.id === modalityId);
			if (modality) {
				(document.getElementById('edit-modality-id')).value = modality.id;
				(document.getElementById('edit-modality-title')).value = modality.title;
				(document.getElementById('edit-modality-description')).value = modality.description;
				const select = document.getElementById('edit-modality-category');
				select.value = modality.category_id || '';
				(document.getElementById('edit-modality-image')).value = modality.image_url || '';
			}
		}

		editModalityModal.classList.remove('hidden');
		document.body.style.overflow = 'hidden';
	};

	window.deleteModality = async function(modalityId, modalityName) {
		const confirmed = await window.modal.show({
			title: 'Eliminar Modalidad',
			message: `¿Estás seguro de que quieres eliminar la modalidad "${modalityName}"? Esta acción no se puede deshacer y se eliminarán todas las clases asociadas.`,
			type: 'warning',
			confirmText: 'Sí, eliminar',
			cancelText: 'Cancelar'
		});
		
		if (!confirmed) return;
		
		const response = await api.deleteModality(modalityId);
		if (response.success) {
			window.toast.success('Modalidad eliminada correctamente');
			await loadAllModalities();
		} else {
			window.toast.error(response.error || 'Error al eliminar la modalidad');
		}
	};

	// Global functions for category management
	window.editCategory = async function(categoryId) {
		// Fetch category data to pre-populate
		const response = await api.getCategories();
		if (response.success && response.data) {
			const category = response.data.find((c) => c.id === categoryId);
			if (category) {
				(document.getElementById('edit-category-id')).value = category.id;
				(document.getElementById('edit-category-title')).value = category.title;
				(document.getElementById('edit-category-slug')).value = category.slug;
				(document.getElementById('edit-category-description')).value = category.description;
				(document.getElementById('edit-category-price')).value = category.price || 0;
			}
		}

		editCategoryModal.classList.remove('hidden');
		document.body.style.overflow = 'hidden';
	};

	window.deleteCategory = async function(categoryId, categoryName) {
		const confirmed = await window.modal.show({
			title: 'Eliminar Categoría',
			message: `¿Estás seguro de que quieres eliminar la categoría "${categoryName}"? Esta acción no se puede deshacer y afectará todas las modalidades asociadas.`,
			type: 'warning',
			confirmText: 'Sí, eliminar',
			cancelText: 'Cancelar'
		});
		
		if (!confirmed) return;
		
		const response = await api.deleteCategory(categoryId);
		if (response.success) {
			window.toast.success('Categoría eliminada correctamente');
			await loadAllCategories();
		} else {
			window.toast.error(response.error || 'Error al eliminar la categoría');
		}
	};

	// Load appropriate dashboard based on role
	if (isClient()) {
		loadClientDashboard();
	} else if (isInstructor()) {
		loadInstructorDashboard();
	} else {
		window.location.href = '/login';
	}
</script>

<style>
	/* Reordenar columnas de la tabla de categorías usando flexbox */
	.category-row-header,
	.category-row {
		display: flex;
		width: 100%;
	}

	.category-row-header > th,
	.category-row > td {
		flex: 1;
		min-width: 0;
	}

	/* Orden original: Categoría, Slug, Descripción, Precio, Acciones */
	/* Nuevo orden visual: Descripción, Precio, Categoría, Slug, Acciones */
	
	.category-title {
		order: 3;
	}

	.category-slug {
		order: 4;
	}

	.category-description {
		order: 1;
		flex: 2; /* Dar más espacio a la descripción */
	}

	.category-price {
		order: 2;
	}

	.category-actions {
		order: 5;
		flex: 0.5; /* Menos espacio para acciones */
	}
</style>
