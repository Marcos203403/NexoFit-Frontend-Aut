	// Tab switching
	function switchTab(tabId) {
		// Hide all tab content
		document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
		// Deactivate all tab buttons
		document.querySelectorAll('.tab-button').forEach(btn => {
			btn.classList.remove('border-orange-500', 'text-orange-500');
			btn.classList.add('border-transparent', 'text-zinc-400');
		});
		// Show selected content
		document.getElementById(tabId.replace('tab-', 'content-'))?.classList.remove('hidden');
		// Activate selected tab button
		const activeBtn = document.getElementById(tabId);
		activeBtn?.classList.add('border-orange-500', 'text-orange-500');
		activeBtn?.classList.remove('border-transparent', 'text-zinc-400');
	}

