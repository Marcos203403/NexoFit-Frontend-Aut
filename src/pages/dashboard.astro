---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mi Dashboard - NexoFit" description="Panel de control de NexoFit">
	<div id="client-dashboard" class="hidden">
		<!-- Client Dashboard -->
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<!-- Welcome Section -->
			<div class="mb-8">
				<h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
					Bienvenido a NexoFit <span id="user-name" class="gradient-text"></span>
				</h1>
				<p class="text-zinc-400">Gestiona tus reservas y descubre nuevas clases</p>
			</div>

			<!-- Upcoming Classes Section -->
			<section class="mb-12">
				<div class="flex items-center justify-between mb-6">
					<h2 class="text-2xl font-bold text-white">Mis Próximas Clases</h2>
					<a href="/categorias" class="text-orange-500 hover:text-orange-400 text-sm font-semibold">
						Ver todas las clases →
					</a>
				</div>

				<!-- Loading State -->
				<div id="upcoming-loading" class="flex items-center justify-center py-12">
					<svg class="animate-spin h-8 w-8 text-orange-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
				</div>

				<!-- Empty State -->
				<div id="upcoming-empty" class="hidden bg-zinc-900 border border-zinc-800 rounded-xl p-12 text-center">
					<svg class="w-16 h-16 text-zinc-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
					</svg>
					<h3 class="text-xl font-semibold text-white mb-2">No tienes clases reservadas</h3>
					<p class="text-zinc-400 mb-6">¡Comienza a entrenar! Explora nuestras clases disponibles</p>
					<a href="/categorias" class="inline-block gradient-primary text-white font-semibold px-6 py-3 rounded-lg">
						Explorar Categorías
					</a>
				</div>

				<!-- Upcoming Classes List -->
				<div id="upcoming-list" class="hidden">
					<div id="upcoming-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
						<!-- Classes will be inserted here -->
					</div>
				</div>
			</section>

			<!-- Available Classes Section -->
			<section>
				<div class="flex items-center justify-between mb-6">
					<h2 class="text-2xl font-bold text-white">Clases Disponibles</h2>
				</div>

				<!-- Loading State -->
				<div id="classes-loading" class="flex items-center justify-center py-12">
					<svg class="animate-spin h-8 w-8 text-orange-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
				</div>

				<!-- Classes Grid -->
				<div id="classes-grid" class="hidden">
					<div id="classes-grid-inner" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
						<!-- Classes will be inserted here -->
					</div>
				</div>
			</section>
		</div>
	</div>

	<div id="instructor-dashboard" class="hidden">
		<!-- Instructor Dashboard -->
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<!-- Welcome Section -->
			<div class="mb-8">
				<h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
					Bienvenido al Panel de Instructor, <span id="instructor-name" class="gradient-text"></span>
				</h1>
				<p class="text-zinc-400">Gestiona tus clases y visualiza tus alumnos</p>
			</div>

			<!-- Quick Stats -->
			<div class="grid md:grid-cols-3 gap-6 mb-12">
				<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
					<div class="flex items-center justify-between">
						<div>
							<p class="text-zinc-400 text-sm mb-1">Clases Programadas</p>
							<p id="stat-total-classes" class="text-3xl font-bold text-white">-</p>
						</div>
						<div class="w-12 h-12 rounded-lg gradient-primary flex items-center justify-center">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
						</div>
					</div>
				</div>

				<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
					<div class="flex items-center justify-between">
						<div>
							<p class="text-zinc-400 text-sm mb-1">Alumnos Totales</p>
							<p id="stat-total-students" class="text-3xl font-bold text-white">-</p>
						</div>
						<div class="w-12 h-12 rounded-lg gradient-primary flex items-center justify-center">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
							</svg>
						</div>
					</div>
				</div>

				<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
					<div class="flex items-center justify-between">
						<div>
							<p class="text-zinc-400 text-sm mb-1">Ocupación Media</p>
							<p id="stat-avg-occupancy" class="text-3xl font-bold text-white">-</p>
						</div>
						<div class="w-12 h-12 rounded-lg gradient-primary flex items-center justify-center">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
							</svg>
						</div>
					</div>
				</div>
			</div>

			<!-- Action Buttons -->
			<div class="flex flex-wrap gap-4 mb-8">
				<button id="btn-create-class" class="gradient-primary text-white font-semibold px-6 py-3 rounded-lg hover:shadow-xl hover:shadow-orange-500/30 transition-all">
					+ Nueva Clase
				</button>
				<button id="btn-create-modality" class="bg-zinc-800 hover:bg-zinc-700 text-white font-semibold px-6 py-3 rounded-lg border border-zinc-700 transition-all">
					+ Nueva Modalidad
				</button>
				<button id="btn-create-category" class="bg-zinc-800 hover:bg-zinc-700 text-white font-semibold px-6 py-3 rounded-lg border border-zinc-700 transition-all">
					+ Nueva Categoría
				</button>
			</div>

			<!-- Tabs Navigation -->
			<div class="border-b border-zinc-800 mb-8">
				<nav class="flex space-x-8 overflow-x-auto">
					<button id="tab-my-classes" class="tab-button active px-1 py-4 text-sm font-semibold border-b-2 border-orange-500 text-orange-500 whitespace-nowrap">
						Mis Clases
					</button>
					<button id="tab-all-classes" class="tab-button px-1 py-4 text-sm font-semibold border-b-2 border-transparent text-zinc-400 hover:text-white hover:border-zinc-700 whitespace-nowrap transition-colors">
						Todas las Clases
					</button>
					<button id="tab-modalities" class="tab-button px-1 py-4 text-sm font-semibold border-b-2 border-transparent text-zinc-400 hover:text-white hover:border-zinc-700 whitespace-nowrap transition-colors">
						Modalidades
					</button>
					<button id="tab-categories" class="tab-button px-1 py-4 text-sm font-semibold border-b-2 border-transparent text-zinc-400 hover:text-white hover:border-zinc-700 whitespace-nowrap transition-colors">
						Categorías
					</button>
				</nav>
			</div>

			<!-- Tab Content: My Classes -->
			<div id="content-my-classes" class="tab-content">
				<h2 class="text-2xl font-bold text-white mb-6">Mis Clases</h2>

				<!-- Loading State -->
				<div id="instructor-classes-loading" class="flex items-center justify-center py-12">
					<svg class="animate-spin h-8 w-8 text-orange-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
				</div>

				<!-- Classes Table -->
				<div id="instructor-classes-table" class="hidden bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden">
					<div class="overflow-x-auto">
						<table class="w-full">
							<thead class="bg-zinc-800">
								<tr>
									<th class="px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Clase</th>
									<th class="px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Fecha y Hora</th>
									<th class="px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Ocupación</th>
									<th class="px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Estado</th>
								</tr>
							</thead>
							<tbody id="instructor-classes-body" class="divide-y divide-zinc-800">
								<!-- Classes will be inserted here -->
							</tbody>
						</table>
					</div>
				</div>
			</div>

			<!-- Tab Content: All Classes -->
			<div id="content-all-classes" class="tab-content hidden">
				<h2 class="text-2xl font-bold text-white mb-6">Todas las Clases</h2>

				<!-- Loading State -->
				<div id="all-classes-loading" class="flex items-center justify-center py-12">
					<svg class="animate-spin h-8 w-8 text-orange-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
				</div>

				<!-- All Classes Table -->
				<div id="all-classes-table" class="hidden bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden">
					<div class="overflow-x-auto">
						<table class="w-full">
							<thead class="bg-zinc-800">
								<tr>
									<th class="px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Clase</th>
									<th class="px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Instructor</th>
									<th class="px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Fecha y Hora</th>
									<th class="px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Ocupación</th>
									<th class="px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Acciones</th>
								</tr>
							</thead>
							<tbody id="all-classes-body" class="divide-y divide-zinc-800">
								<!-- Classes will be inserted here -->
							</tbody>
						</table>
					</div>
				</div>
			</div>

			<!-- Tab Content: Modalities -->
			<div id="content-modalities" class="tab-content hidden">
				<h2 class="text-2xl font-bold text-white mb-6">Modalidades</h2>

				<!-- Loading State -->
				<div id="all-modalities-loading" class="flex items-center justify-center py-12">
					<svg class="animate-spin h-8 w-8 text-orange-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
				</div>

				<!-- All Modalities Grid -->
				<div id="all-modalities-grid" class="hidden">
					<!-- Modalities will be inserted here -->
				</div>
			</div>

			<!-- Tab Content: Categories -->
			<div id="content-categories" class="tab-content hidden">
				<h2 class="text-2xl font-bold text-white mb-6">Categorías</h2>

				<!-- Loading State -->
				<div id="all-categories-loading" class="flex items-center justify-center py-12">
					<svg class="animate-spin h-8 w-8 text-orange-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
				</div>

				<!-- All Categories Table -->
				<div id="all-categories-table" class="hidden bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden">
					<div class="overflow-x-auto">
						<table class="w-full">
							<thead class="bg-zinc-800">
								<tr class="category-row-header">
									<th class="category-title px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Categoría</th>
									<th class="category-slug px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Slug</th>
									<th class="category-description px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Descripción</th>
									<th class="category-price px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Precio</th>
									<th class="category-actions px-6 py-4 text-left text-xs font-semibold text-zinc-400 uppercase tracking-wider">Acciones</th>
								</tr>
							</thead>
							<tbody id="all-categories-body" class="divide-y divide-zinc-800">
								<!-- Categories will be inserted here -->
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Edit Class Modal -->
	<div id="edit-class-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
		<div class="fixed inset-0 bg-black/80 transition-opacity"></div>
		<div class="relative min-h-screen flex items-center justify-center p-4">
			<div class="relative bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl max-w-md w-full p-6">
				<div class="flex items-center justify-between mb-6">
					<h3 class="text-2xl font-bold text-white">Editar Clase</h3>
					<button id="close-edit-class-modal" class="text-zinc-400 hover:text-white transition-colors">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>
				<form id="edit-class-form" class="space-y-4">
					<input type="hidden" id="edit-class-id" />
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Modalidad</label>
						<select id="edit-class-modality" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
							<option value="">Selecciona una modalidad...</option>
						</select>
					</div>
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Fecha y Hora de Inicio</label>
						<input type="datetime-local" id="edit-class-start-time" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
					</div>
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Fecha y Hora de Fin</label>
						<input type="datetime-local" id="edit-class-end-time" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
					</div>
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Capacidad Máxima</label>
						<input type="number" id="edit-class-capacity" min="1" max="50" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
					</div>
					<div class="flex gap-3 pt-4">
						<button type="button" id="cancel-edit-class-btn" class="flex-1 bg-zinc-800 hover:bg-zinc-700 text-white px-4 py-2.5 rounded-lg font-semibold transition-all">
							Cancelar
						</button>
						<button type="submit" class="flex-1 gradient-primary text-white px-4 py-2.5 rounded-lg font-semibold hover:shadow-lg transition-all">
							Guardar Cambios
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>

	<!-- Edit Modality Modal -->
	<div id="edit-modality-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
		<div class="fixed inset-0 bg-black/80 transition-opacity"></div>
		<div class="relative min-h-screen flex items-center justify-center p-4">
			<div class="relative bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl max-w-md w-full p-6">
				<div class="flex items-center justify-between mb-6">
					<h3 class="text-2xl font-bold text-white">Editar Modalidad</h3>
					<button id="close-edit-modality-modal" class="text-zinc-400 hover:text-white transition-colors">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>
				<form id="edit-modality-form" class="space-y-4">
					<input type="hidden" id="edit-modality-id" />
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Nombre de la Modalidad</label>
						<input type="text" id="edit-modality-title" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
					</div>
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Descripción</label>
						<textarea id="edit-modality-description" rows="3" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500 resize-none"></textarea>
					</div>
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Categoría</label>
						<select id="edit-modality-category" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
							<option value="">Selecciona una categoría...</option>
						</select>
					</div>
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">URL de Imagen</label>
						<input type="url" id="edit-modality-image" class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
					</div>
					<div class="flex gap-3 pt-4">
						<button type="button" id="cancel-edit-modality-btn" class="flex-1 bg-zinc-800 hover:bg-zinc-700 text-white px-4 py-2.5 rounded-lg font-semibold transition-all">
							Cancelar
						</button>
						<button type="submit" class="flex-1 gradient-primary text-white px-4 py-2.5 rounded-lg font-semibold hover:shadow-lg transition-all">
							Guardar Cambios
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>

	<!-- Edit Category Modal -->
	<div id="edit-category-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
		<div class="fixed inset-0 bg-black/80 transition-opacity"></div>
		<div class="relative min-h-screen flex items-center justify-center p-4">
			<div class="relative bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl max-w-md w-full p-6">
				<div class="flex items-center justify-between mb-6">
					<h3 class="text-2xl font-bold text-white">Editar Categoría</h3>
					<button id="close-edit-category-modal" class="text-zinc-400 hover:text-white transition-colors">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
