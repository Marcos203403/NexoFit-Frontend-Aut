	// Form submissions
	document.getElementById('create-class-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		
		const modalityId = parseInt((document.getElementById('class-modality')).value);
		const startTimeRaw = (document.getElementById('class-start-time')).value;
		const endTimeRaw = (document.getElementById('class-end-time')).value;
		const capacity = parseInt((document.getElementById('class-capacity')).value);

		if (!modalityId || !startTimeRaw || !endTimeRaw || !capacity) {
			window.toast.error('Por favor completa todos los campos');
			return;
		}

		// Convert datetime-local format to ISO 8601
		const startTime = new Date(startTimeRaw).toISOString();
		const endTime = new Date(endTimeRaw).toISOString();

		// Validate end time is after start time
		if (new Date(endTimeRaw) <= new Date(startTimeRaw)) {
			window.toast.error('La hora de fin debe ser posterior a la hora de inicio');
			return;
		}

		const response = await api.createClass({
			modalityId,
			instructorId: user!.id,
			startTime,
			endTime,
			capacity
		});

		if (response.success) {
			window.toast.success('¡Clase creada exitosamente!');
			closeModal(createClassModal);
			setTimeout(() => window.location.reload(), 1500);
		} else {
			window.toast.error(response.error || 'Error al crear la clase');
		}
	});

	document.getElementById('create-modality-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		
		const title = (document.getElementById('modality-title')).value;
		const description = (document.getElementById('modality-description')).value;
		const categoryId = parseInt((document.getElementById('modality-category')).value);
		const imageUrl = (document.getElementById('modality-image')).value;

		if (!title || !description || !categoryId) {
			window.toast.error('Por favor completa todos los campos obligatorios');
			return;
		}

		const response = await api.createModality({
			title,
			description,
			categoryId,
			imageUrl: imageUrl || undefined
		});

		if (response.success) {
			window.toast.success('¡Modalidad creada exitosamente!');
			closeModal(createModalityModal);
			// Reset form
			(document.getElementById('create-modality-form')).reset();
		} else {
			window.toast.error(response.error || 'Error al crear la modalidad');
		}
	});

	document.getElementById('create-category-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		
		const title = (document.getElementById('category-title')).value;
		const slug = (document.getElementById('category-slug')).value;
		const description = (document.getElementById('category-description')).value;
		const price = parseFloat((document.getElementById('category-price')).value);

		if (!title || !slug || !description || isNaN(price)) {
			window.toast.error('Por favor completa todos los campos');
			return;
		}

		// Validate slug format
		const slugRegex = /^[a-z0-9-]+$/;
		if (!slugRegex.test(slug)) {
			window.toast.error('El slug solo puede contener letras minúsculas, números y guiones');
			return;
		}

		if (price < 0) {
			window.toast.error('El precio debe ser mayor o igual a 0');
			return;
		}

		const response = await api.createCategory({
			title,
			slug,
			description,
			price
		});

		if (response.success) {
			window.toast.success('¡Categoría creada exitosamente!');
			closeModal(createCategoryModal);
			// Reset form
			(document.getElementById('create-category-form')).reset();
			await loadAllCategories();
		} else {
			window.toast.error(response.error || 'Error al crear la categoría');
		}
	});

	// Auto-generate slug from category title
	document.getElementById('category-title')?.addEventListener('input', (e) => {
		const title = (e.target).value;
		const slugInput = document.getElementById('category-slug');
		if (!slugInput.value || slugInput.dataset.autoGenerated === 'true') {
			const slug = title
				.toLowerCase()
				.normalize('NFD')
				.replace(/[\u0300-\u036f]/g, '') // Remove accents
				.replace(/[^a-z0-9\s-]/g, '') // Remove special chars
				.replace(/\s+/g, '-') // Replace spaces with hyphens
				.replace(/-+/g, '-') // Remove duplicate hyphens
				.trim();
			slugInput.value = slug;
			slugInput.dataset.autoGenerated = 'true';
		}
	});

	document.getElementById('category-slug')?.addEventListener('input', (e) => {
		const input = e.target;
		if (input.value) {
			delete input.dataset.autoGenerated;
		}
	});

