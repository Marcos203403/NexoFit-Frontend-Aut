	// Global functions for class management
	window.editClass = async function(classId) {
		// Load modalities for the select
		const modalitiesResponse = await api.getModalities();
		if (modalitiesResponse.success && modalitiesResponse.data) {
			const select = document.getElementById('edit-class-modality');
			select.innerHTML = '<option value="">Selecciona una modalidad...</option>';
			modalitiesResponse.data.forEach((modality) => {
				const option = document.createElement('option');
				option.value = modality.id;
				option.textContent = modality.title;
				select.appendChild(option);
			});
		}

		// Fetch class data to pre-populate
		const response = await api.getClasses();
		if (response.success && response.data) {
			const cls = response.data.find((c) => c.id === classId);
			if (cls) {
				(document.getElementById('edit-class-id')).value = cls.id;
				const select = document.getElementById('edit-class-modality');
				select.value = cls.modality_id || '';
				// Convert ISO to datetime-local format (YYYY-MM-DDTHH:mm)
				const toLocalInput = (iso) => new Date(iso).toISOString().slice(0, 16);
				(document.getElementById('edit-class-start-time')).value = toLocalInput(cls.start_time);
				(document.getElementById('edit-class-end-time')).value = toLocalInput(cls.end_time);
				(document.getElementById('edit-class-capacity')).value = cls.capacity;
			}
		}

		editClassModal.classList.remove('hidden');
		document.body.style.overflow = 'hidden';
	};

