						</svg>
					</button>
				</div>
				<form id="edit-category-form" class="space-y-4">
					<input type="hidden" id="edit-category-id" />
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Nombre de la Categoría</label>
						<input type="text" id="edit-category-title" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
					</div>
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Slug (URL amigable)</label>
						<input type="text" id="edit-category-slug" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
						<p class="text-zinc-500 text-xs mt-1">Solo letras minúsculas, números y guiones</p>
					</div>
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Descripción</label>
						<textarea id="edit-category-description" rows="3" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500 resize-none"></textarea>
					</div>
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Precio (€)</label>
						<input type="number" id="edit-category-price" min="0" step="0.01" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
					</div>
					<div class="flex gap-3 pt-4">
