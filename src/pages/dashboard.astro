					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Fecha y Hora de Inicio</label>
						<input type="datetime-local" id="class-start-time" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
					</div>

					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Fecha y Hora de Fin</label>
						<input type="datetime-local" id="class-end-time" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" />
					</div>

					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Capacidad Máxima</label>
						<input type="number" id="class-capacity" min="1" max="50" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="Ej: 15" />
					</div>

					<div class="flex gap-3 pt-4">
						<button type="button" id="cancel-class-btn" class="flex-1 bg-zinc-800 hover:bg-zinc-700 text-white px-4 py-2.5 rounded-lg font-semibold transition-all">
							Cancelar
						</button>
						<button type="submit" class="flex-1 gradient-primary text-white px-4 py-2.5 rounded-lg font-semibold hover:shadow-lg transition-all">
							Crear Clase
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>

	<!-- Create Modality Modal -->
	<div id="create-modality-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
		<div class="fixed inset-0 bg-black/80 transition-opacity"></div>
		<div class="relative min-h-screen flex items-center justify-center p-4">
			<div class="relative bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl max-w-md w-full p-6">
				<div class="flex items-center justify-between mb-6">
					<h3 class="text-2xl font-bold text-white">Nueva Modalidad</h3>
					<button id="close-modality-modal" class="text-zinc-400 hover:text-white transition-colors">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>

				<form id="create-modality-form" class="space-y-4">
					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Nombre de la Modalidad</label>
						<input type="text" id="modality-title" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="Ej: Yoga Vinyasa" />
					</div>

					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Descripción</label>
						<textarea id="modality-description" rows="3" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500 resize-none" placeholder="Describe la modalidad..."></textarea>
					</div>

					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">Categoría</label>
						<select id="modality-category" required class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
							<option value="">Selecciona una categoría...</option>
						</select>
					</div>

					<div>
						<label class="block text-sm font-semibold text-zinc-300 mb-2">URL de Imagen</label>
						<input type="url" id="modality-image" class="w-full px-4 py-2.5 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="https://..." />
					</div>

					<div class="flex gap-3 pt-4">
						<button type="button" id="cancel-modality-btn" class="flex-1 bg-zinc-800 hover:bg-zinc-700 text-white px-4 py-2.5 rounded-lg font-semibold transition-all">
							Cancelar
