	<!-- Loading Screen -->
	<div id="loading-screen" class="flex items-center justify-center min-h-screen">
		<div class="text-center">
			<img src="/logo-192x192.png" alt="NexoFit Logo" class="w-24 h-24 mx-auto mb-4 animate-pulse" />
			<p class="text-zinc-400">Cargando...</p>
